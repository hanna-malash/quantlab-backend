# Python
__pycache__/
*.py[cod]

# Virtual env
.venv/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# pytest cache
.pytest_cache/

# Data (do not commit large datasets by default)
data/raw/*
data/normalized/*

# keep folder structure
!data/raw/.gitkeep
!data/normalized/.gitkeep

# allow demo dataset (used by API + frontend out-of-the-box)
!data/normalized/BTCUSDT_1h.csv

# allow Stooq daily raw datasets (history)
!data/raw/*_d.csv
!data/raw/*_us_d.csv

# allow normalized daily datasets (history)
!data/normalized/*_1d.csv
